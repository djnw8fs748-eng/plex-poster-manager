# Required — base URL of your Plex Media Server
PLEX_URL=http://192.168.1.10:32400

# Required — your Plex account auth token
# Find it at: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=your_plex_token_here

# Optional — comma-separated list of library names or IDs to process
# Leave empty to process all libraries
PLEX_LIBRARIES=Movies,TV Shows

# Optional — set to true to log what would be deleted without actually deleting anything
# Always test with DRY_RUN=true first!
DRY_RUN=true

# Optional — cron expression to run on a schedule (e.g. daily at 3am)
# If not set, the container runs once and exits
SCHEDULE_CRON=0 3 * * *

# Optional — logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
